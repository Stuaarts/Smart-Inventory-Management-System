@page
@model SmartInventory.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-shell">
    <section class="surface auth-card">
        <p class="page-kicker">StockPilot access</p>
        <h1 class="h2 mb-2">Welcome back</h1>
        <p class="text-secondary mb-4">Sign in to manage inventory, sales orders, suppliers, and stock activity.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="admin@demo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Demo123!" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Log in</button>
        </form>

        <div class="auth-footnote">
            <span>New to StockPilot?</span>
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
