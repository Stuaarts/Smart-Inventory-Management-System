@model Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">@Model.Name</h1>
        <p class="text-secondary mb-0">@(Model.ContactName ?? "No contact name")</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.SupplierId">Edit</a>
    }
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <section class="surface">
            <h2 class="h5 mb-3">Contact</h2>
            <dl class="row mb-0 detail-list">
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@(Model.Email ?? "-")</dd>
                <dt class="col-sm-4">Phone</dt>
                <dd class="col-sm-8">@(Model.Phone ?? "-")</dd>
                <dt class="col-sm-4">Address</dt>
                <dd class="col-sm-8">@($"{Model.Address} {Model.City} {Model.Province} {Model.PostalCode}".Trim())</dd>
                <dt class="col-sm-4">Country</dt>
                <dd class="col-sm-8">@(Model.Country ?? "-")</dd>
            </dl>
        </section>
    </div>
    <div class="col-lg-8">
        <section class="surface">
            <div class="section-heading">
                <h2>Products</h2>
                <span class="text-secondary">@Model.Products.Count items</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Stock</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Products.Any())
                    {
                        foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">@product.Name</a>
                                    <div class="small text-secondary">@product.SKU</div>
                                </td>
                                <td class="text-end">@product.QuantityInStock</td>
                                <td>@await Html.PartialAsync("_StockBadge", product)</td>
                                <td class="text-end"><a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">Open</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-secondary">No products from this supplier.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
