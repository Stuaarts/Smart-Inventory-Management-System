@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

@await Html.PartialAsync("_StatusMessage")

<div class="page-header">
    <div>
        <p class="page-kicker">Operations overview</p>
        <h1>Dashboard</h1>
        <p>Monitor inventory value, stock risk, order activity, and the latest inventory changes.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Products" asp-action="LowStock">Review Alerts</a>
        <a class="btn btn-outline-primary" asp-controller="Orders" asp-action="Create">New Order</a>
        <a class="btn btn-primary" asp-controller="StockMovements" asp-action="Create">Record Movement</a>
    </div>
</div>

<div class="dashboard-grid mb-4">
    <div class="stat-card accent-primary">
        <span>Total Products</span>
        <strong>@Model.TotalProducts</strong>
        <small>Active catalog items</small>
    </div>
    <div class="stat-card accent-warning">
        <span>Low Stock</span>
        <strong>@Model.LowStockCount</strong>
        <small>Need restock review</small>
    </div>
    <div class="stat-card accent-danger">
        <span>Out of Stock</span>
        <strong>@Model.OutOfStockCount</strong>
        <small>Currently unavailable</small>
    </div>
    <div class="stat-card accent-success">
        <span>Inventory Value</span>
        <strong>@Model.TotalInventoryValue.ToString("C")</strong>
        <small>Based on cost price</small>
    </div>
    <div class="stat-card accent-indigo">
        <span>Potential Revenue</span>
        <strong>@Model.PotentialRevenue.ToString("C")</strong>
        <small>Based on sale price</small>
    </div>
    <div class="stat-card accent-slate">
        <span>Total Orders</span>
        <strong>@Model.TotalOrders</strong>
        <small>Sales records</small>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        <section class="surface table-surface">
            <div class="section-heading">
                <h2>Low Stock Products</h2>
                <a asp-controller="Products" asp-action="LowStock">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Current</th>
                            <th>Minimum</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.LowStockProducts.Any())
                    {
                        foreach (var product in Model.LowStockProducts)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">@product.Name</a>
                                    <div class="small text-secondary">@product.SKU</div>
                                </td>
                                <td>@product.Category?.Name</td>
                                <td>@product.QuantityInStock</td>
                                <td>@product.MinimumStockLevel</td>
                                <td>@await Html.PartialAsync("_StockBadge", product)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-secondary">All tracked products are above their minimum stock level.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
    <div class="col-xl-5">
        <section class="surface">
            <div class="section-heading">
                <h2>Recent Movements</h2>
                <a asp-controller="StockMovements" asp-action="Index">View all</a>
            </div>
            <div class="activity-list">
            @if (Model.RecentStockMovements.Any())
            {
                foreach (var movement in Model.RecentStockMovements)
                {
                    <div class="activity-row">
                        <div>
                            <strong>@movement.Product?.Name</strong>
                            <div class="small text-secondary">@movement.MovementType.GetDisplayName() by @movement.Quantity units</div>
                        </div>
                        <div class="text-end">
                            <span class="fw-semibold">@movement.PreviousQuantity -> @movement.NewQuantity</span>
                            <div class="small text-secondary">@movement.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-secondary mb-0">Stock changes will appear here as inventory is received, sold, or adjusted.</p>
            }
            </div>
        </section>
    </div>
    <div class="col-12">
        <section class="surface table-surface">
            <div class="section-heading">
                <h2>Recent Orders</h2>
                <a asp-controller="Orders" asp-action="Index">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th class="text-end">Total</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.RecentOrders.Any())
                    {
                        foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td><a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderId">@order.OrderNumber</a></td>
                                <td>@(order.CustomerName ?? "Walk-in customer")</td>
                                <td><span class="status-pill status-@order.Status.ToString().ToLowerInvariant()">@order.Status</span></td>
                                <td class="text-end">@order.TotalAmount.ToString("C")</td>
                                <td>@order.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-secondary">Orders will appear here once sales are captured.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
