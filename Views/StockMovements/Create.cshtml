@model StockMovementCreateViewModel

@{
    ViewData["Title"] = "Record Stock Movement";
}

<div class="content-narrow">
    <div class="mb-4">
        <h1 class="h2 mb-1">Record Stock Movement</h1>
        <p class="text-secondary mb-0">Stock In and Return add units. Stock Out, Sale, and Damaged remove units. Adjustment sets the new stock quantity.</p>
    </div>
    <form asp-action="Create" class="surface">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="ProductId" class="form-label">Product</label>
            <select asp-for="ProductId" class="form-select" asp-items="Model.ProductOptions">
                <option value="">Select product</option>
            </select>
            <span asp-validation-for="ProductId" class="text-danger"></span>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="MovementType" class="form-label"></label>
                <select asp-for="MovementType" class="form-select" asp-items="Html.GetEnumSelectList<StockMovementType>()"></select>
                <span asp-validation-for="MovementType" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Quantity" class="form-label">Quantity / New quantity for adjustment</label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
        </div>
        <div class="mt-3">
            <label asp-for="Reason" class="form-label"></label>
            <textarea asp-for="Reason" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Reason" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Record Movement</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
