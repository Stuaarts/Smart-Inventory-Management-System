@model IEnumerable<AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<div class="mb-4">
    <h1 class="h2 mb-1">Audit Logs</h1>
    <p class="text-secondary mb-0">Recent tracked actions in the system.</p>
</div>

<section class="surface">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Description</th>
                    <th>User Id</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Any())
            {
                foreach (var log in Model)
                {
                    <tr>
                        <td>@log.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td>@log.Action</td>
                        <td>@log.EntityName #@log.EntityId</td>
                        <td>@log.Description</td>
                        <td class="small text-secondary">@log.UserId</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-secondary">No audit logs yet.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
