@model IEnumerable<AdminUserViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Users</h1>
        <p class="text-secondary mb-0">Team access levels for inventory, order, and admin workflows.</p>
    </div>
</div>

<section class="surface">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Email Confirmed</th>
                    <th>Lockout End</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.Roles</td>
                    <td><span class="badge @(user.EmailConfirmed ? "text-bg-success" : "text-bg-secondary")">@(user.EmailConfirmed ? "Yes" : "No")</span></td>
                    <td>@(user.LockoutEnd?.ToString("g") ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
