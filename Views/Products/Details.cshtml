@model Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">@Model.Name</h1>
        <p class="text-secondary mb-0">@Model.SKU</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-controller="StockMovements" asp-action="Create" asp-route-productId="@Model.ProductId">Record Stock</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.ProductId">Edit</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <section class="surface">
            <h2 class="h5 mb-3">Product Information</h2>
            <dl class="row mb-0 detail-list">
                <dt class="col-sm-5">Status</dt>
                <dd class="col-sm-7">@await Html.PartialAsync("_StockBadge", Model)</dd>
                <dt class="col-sm-5">Category</dt>
                <dd class="col-sm-7">@Model.Category?.Name</dd>
                <dt class="col-sm-5">Supplier</dt>
                <dd class="col-sm-7">@(Model.Supplier?.Name ?? "-")</dd>
                <dt class="col-sm-5">Cost Price</dt>
                <dd class="col-sm-7">@Model.CostPrice.ToString("C")</dd>
                <dt class="col-sm-5">Unit Price</dt>
                <dd class="col-sm-7">@Model.UnitPrice.ToString("C")</dd>
                <dt class="col-sm-5">Inventory Value</dt>
                <dd class="col-sm-7">@Model.InventoryValue.ToString("C")</dd>
                <dt class="col-sm-5">Stock</dt>
                <dd class="col-sm-7">@Model.QuantityInStock / @Model.MinimumStockLevel</dd>
                <dt class="col-sm-5">Barcode</dt>
                <dd class="col-sm-7">@(Model.Barcode ?? "-")</dd>
            </dl>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <hr />
                <p class="text-secondary mb-0">@Model.Description</p>
            }
        </section>
    </div>
    <div class="col-lg-7">
        <section class="surface">
            <div class="section-heading">
                <h2>Recent Stock Movements</h2>
                <a asp-controller="StockMovements" asp-action="Index" asp-route-productId="@Model.ProductId">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Before</th>
                            <th class="text-end">After</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.StockMovements.Any())
                    {
                        foreach (var movement in Model.StockMovements)
                        {
                            <tr>
                                <td>@movement.MovementType.GetDisplayName()</td>
                                <td class="text-end">@movement.Quantity</td>
                                <td class="text-end">@movement.PreviousQuantity</td>
                                <td class="text-end">@movement.NewQuantity</td>
                                <td>@movement.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-secondary">No movement history for this product.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
