@{
    ViewData["Title"] = "Inventory Command Center";
}

<section class="hero-band">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <p class="page-kicker">StockPilot inventory platform</p>
            <h1 class="display-5 fw-semibold mb-3">Inventory control built for fast-moving retail teams.</h1>
            <p class="lead text-secondary mb-4">
                StockPilot brings products, suppliers, stock alerts, sales orders, and inventory history into one clean operating dashboard.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Login">Open Dashboard</a>
                <a class="btn btn-outline-secondary btn-lg" asp-area="Identity" asp-page="/Account/Register">Create Account</a>
            </div>
            <div class="hero-proof">
                <span>Role-based access</span>
                <span>PostgreSQL backed</span>
                <span>Stock movement audit trail</span>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="preview-panel app-preview">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <div class="text-uppercase text-secondary small fw-semibold">Live inventory</div>
                        <div class="h4 mb-0">StockPilot</div>
                    </div>
                    <span class="badge text-bg-warning">Low stock: 2</span>
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="metric-tile accent-primary">
                            <span>Total Products</span>
                            <strong>124</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-tile accent-success">
                            <span>Inventory Value</span>
                            <strong>$12.4k</strong>
                        </div>
                    </div>
                </div>
                <div class="table-responsive mt-4">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Stock</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Tea Tree Shampoo</td>
                                <td>4 / 10</td>
                                <td><span class="badge text-bg-warning">Low Stock</span></td>
                            </tr>
                            <tr>
                                <td>Cape Clips Pack</td>
                                <td>0 / 5</td>
                                <td><span class="badge text-bg-danger">Out of Stock</span></td>
                            </tr>
                            <tr>
                                <td>Travel Comb Set</td>
                                <td>32 / 12</td>
                                <td><span class="badge text-bg-success">In Stock</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
