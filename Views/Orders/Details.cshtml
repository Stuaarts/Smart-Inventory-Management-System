@model Order

@{
    ViewData["Title"] = "Order Details";
}

@await Html.PartialAsync("_StatusMessage")

<div class="page-header">
    <div>
        <p class="page-kicker">Order details</p>
        <h1>@Model.OrderNumber</h1>
        <p>@(Model.CustomerName ?? "Walk-in customer")</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if ((User.IsInRole("Admin") || User.IsInRole("Manager")) && Model.Status == OrderStatus.Draft)
        {
            <form asp-action="Complete" asp-route-id="@Model.OrderId" method="post">
                <button type="submit" class="btn btn-primary">Complete Order</button>
            </form>
            <form asp-action="Cancel" asp-route-id="@Model.OrderId" method="post">
                <button type="submit" class="btn btn-outline-danger">Cancel Draft</button>
            </form>
        }
        <a class="btn btn-outline-secondary" asp-action="Index">Back to Orders</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <section class="surface">
            <h2 class="h5 mb-3">Summary</h2>
            <dl class="row mb-0 detail-list">
                <dt class="col-sm-5">Status</dt>
                <dd class="col-sm-7"><span class="status-pill status-@Model.Status.ToString().ToLowerInvariant()">@Model.Status</span></dd>
                <dt class="col-sm-5">Customer</dt>
                <dd class="col-sm-7">@(Model.CustomerName ?? "Walk-in customer")</dd>
                <dt class="col-sm-5">Email</dt>
                <dd class="col-sm-7">@(Model.CustomerEmail ?? "-")</dd>
                <dt class="col-sm-5">Order Date</dt>
                <dd class="col-sm-7">@Model.OrderDate.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</dd>
                <dt class="col-sm-5">Total</dt>
                <dd class="col-sm-7 fw-semibold">@Model.TotalAmount.ToString("C")</dd>
            </dl>
        </section>
    </div>
    <div class="col-lg-8">
        <section class="surface table-surface">
            <div class="section-heading">
                <h2>Line Items</h2>
                <span class="text-secondary">@Model.OrderItems.Count item(s)</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>
                                @item.Product?.Name
                                <div class="small text-secondary">@item.Product?.SKU</div>
                            </td>
                            <td class="text-end">@item.Quantity</td>
                            <td class="text-end">@item.UnitPrice.ToString("C")</td>
                            <td class="text-end fw-semibold">@item.LineTotal.ToString("C")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
